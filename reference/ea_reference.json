    {
      "name": "to_f32(ptr[i]) not to_f32(to_i32(ptr[i]))",
      "category": "gotcha",
      "signature": "to_f32(ptr[i])",
      "description": "CRITICAL float read pattern. Use to_f32(ptr[i]) directly to read floats from a pointer. to_i32() truncates the float value, losing precision. to_f32(to_i32(ptr[i])) is wrong."
    },
    {
      "name": "no scalar bitwise ops",
      "category": "gotcha",
      "signature": ".& .| .^",
      "description": "Ea has no scalar bitwise operators. Use dot-operators (.& .| .^) on vectors only. Attempting scalar bitwise ops is a compile error."
    },
    {
      "name": "no to_u8()",
      "category": "gotcha",
      "signature": "i32 aliasing",
      "description": "Ea has no to_u8() conversion. For NaN check via IEEE 754 bit inspection, use i32 aliasing with bit manipulation via i32 reinterpretation."
    },
    {
      "name": "shift operators version",
      "category": "gotcha",
      "signature": ".<< .>>",
      "description": "The .<< and .>> shift operators require Ea v1.9.0+. They are not available in older compiler versions."
    },
    {
      "name": "ea compiler not on PATH",
      "category": "gotcha",
      "signature": "/root/dev/eacompute/target/release/ea",
      "description": "The Ea compiler binary is not on PATH. Use the full path: /root/dev/eacompute/target/release/ea"
    }
